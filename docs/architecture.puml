@startuml
title Test Data Agent Architecture

skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam defaultTextAlignment center

actor "User / Agent" as User

package "Inputs" {
  file "Single CSV\n(potentially sensitive)" as SingleCsv
  folder "Example Dataset Folder\n*.csv per entity" as ExampleFolder
  database "Trino\n(read-only)" as Trino
  artifact "GenerationSpec\nJSON" as LegacySpecFile
  artifact "DatasetSpec\nYAML" as DatasetSpecFile
  artifact "Business Rules\nYAML / JSON" as RuleFile
}

package "Interfaces" {
  component "cli.py\nprofile-csv, generate,\ngenerate-from-csv,\nprofile-example, infer-spec,\ngenerate-from-example,\nvalidate, agent-plan,\nagent-approve" as Cli
  component "mcp_trino_server.py\nSafe Trino MCP Tools" as TrinoMcp
  component "mcp_generator_server.py\nProfile, Infer, Generate,\nValidate, Export" as GeneratorMcp
}

package "Review-First Agent Layer" {
  component "agent.py\nAgentRequest / AgentResult\nplan_agent_request\napprove_agent_workspace" as AgentLayer
  component "Agent Approval Gate\nhuman reviews DatasetSpec\nbefore generation" as ApprovalGate
  artifact "Agent Workspace\nagent_request.json\nagent_plan.json\nprofile.json\ndataset_spec.yaml" as AgentWorkspace
  artifact "Agent Result Bundle\nagent_result.json\ngenerated/*\nmanifest + validation report" as AgentBundle
}

package "Safety Controls" {
  component "SQL Safety Checks\nread-only, bounded LIMIT,\nno DDL/DML, no SELECT *" as SqlSafety
  component "PII Detection + Masking\nsensitive by default" as PiiMasking
  component "No Raw Row Copying\nsynthetic output only" as NoCopy
  component "Workspace Path Boundary\nno traversal or symlink escape" as WorkspaceBoundary
  component "Safe Profile Validation\nno raw sensitive distributions" as ProfileSafety
}

package "Legacy Single-Table Flow" {
  component "csv_profiler.py\nSingle CSV Profiler" as CsvProfiler
  component "spec.py\nGenerationSpec / ColumnSpec" as LegacySpec
  component "generator.py\nDeterministic Row Generator" as LegacyGenerator
  component "validator.py\nSingle-table Schema Validation" as LegacyValidator
  artifact "Safe Table Profile\nschema, nulls, ranges,\nmasked patterns" as TableProfile
  artifact "Synthetic Table Rows" as TableRows
}

package "Domain-Agnostic Dataset Flow" {
  package "core/" {
    component "dataset.py\nDatasetProfile / DatasetSpec" as DatasetModels
    component "entity.py\nEntityProfile / EntitySpec" as EntityModels
    component "field.py\nFieldProfile / FieldSpec" as FieldModels
    component "relationship.py\nRelationship" as RelationshipModel
    component "constraint.py\nConstraint" as ConstraintModel
  }

  package "profiling/" {
    component "schema_profiler.py\nCSV folder schema profiling" as SchemaProfiler
    component "distribution_profiler.py\nSafe distributions" as DistributionProfiler
    component "relationship_profiler.py\nFK inference" as RelationshipProfiler
    component "constraint_miner.py\nFormula, temporal,\nconditional, aggregate inference" as ConstraintMiner
  }

  package "generation/" {
    component "planner.py\nDatasetProfile -> DatasetSpec" as Planner
    component "entity_generator.py\nMulti-entity synthetic generation" as EntityGenerator
    component "constraint_solver.py\nFK, formula, temporal,\nconditional, aggregate solving" as ConstraintSolver
  }

  package "validation/" {
    component "schema_validator.py\nEntity schema validation" as DatasetSchemaValidator
    component "relationship_validator.py\nRelationship validation" as RelationshipValidator
    component "constraint_validator.py\nConstraint validation" as ConstraintValidator
    component "reconciliation.py\nCombined validation report" as Reconciliation
  }

  artifact "DatasetProfile\nentities, fields,\nrelationships, constraints" as DatasetProfile
  artifact "DatasetSpec\nentity row counts,\nfields, relationships,\nconstraints" as DatasetSpec
  artifact "Synthetic Dataset\none output file per entity" as DatasetRows
  artifact "Dataset Validation Report\nschema, relationships,\nconstraints" as DatasetReport
}

package "Business Rule Layer" {
  component "business_rules.py\nRule Models + Loader" as RuleModels
  component "rules_engine.py\nScenarios + controlled invalid cases" as RulesEngine
  component "business_validator.py\nExecutable business validation" as BusinessValidator
  artifact "Business Validation Report" as BusinessReport
}

package "Outputs" {
  file "CSV" as CsvOut
  file "JSON" as JsonOut
  file "Parquet" as ParquetOut
  artifact "Artifacts\nprofile.json / csv_profile.json\ngeneration_spec.json / dataset_spec.yaml\nvalidation_report.json\nbusiness_validation_report.json" as Artifacts
  artifact "Generation Manifest\nversion, spec hash, seed, format,\nrow counts, validation, provenance" as Manifest
}

User --> Cli : runs commands
User --> GeneratorMcp : MCP synthetic workflow
User --> LegacySpecFile : writes/reviews
User --> DatasetSpecFile : writes/reviews
User --> RuleFile : optional rules

Cli --> AgentLayer : agent-plan /\nagent-approve
AgentLayer --> CsvProfiler : single CSV planning
AgentLayer --> SchemaProfiler : CSV-folder planning
AgentLayer --> Planner : infer reviewable\nDatasetSpec
AgentLayer --> AgentWorkspace : writes plan artifacts
AgentWorkspace --> ApprovalGate : dataset_spec.yaml\nreview/edit
User --> ApprovalGate : approves reviewed spec
ApprovalGate --> AgentLayer : approve workspace
AgentLayer --> EntityGenerator : approved deterministic\ngeneration
AgentLayer --> Reconciliation : approved validation
AgentLayer --> NoCopy : source-row reuse checks
AgentLayer --> AgentBundle : writes final result

Cli --> CsvProfiler : profile-csv /\ngenerate-from-csv
SingleCsv --> CsvProfiler
CsvProfiler --> PiiMasking
CsvProfiler --> TableProfile : safe metadata only
TableProfile --> LegacySpec : from_csv_profile

Cli --> TrinoMcp : MCP metadata/profiling calls
TrinoMcp --> SqlSafety
TrinoMcp --> Trino : allowed read-only queries
TrinoMcp --> PiiMasking
TrinoMcp --> TableProfile : metadata, aggregates,\nmasked samples
TrinoMcp --> GeneratorMcp : inline safe profile payload
TableProfile --> LegacySpec : from_trino_profile

GeneratorMcp --> WorkspaceBoundary
GeneratorMcp --> ProfileSafety
GeneratorMcp --> Planner : infer_dataset_spec
GeneratorMcp --> EntityGenerator : generate / export
GeneratorMcp --> Reconciliation : validate_dataset

LegacySpecFile --> LegacySpec
LegacySpec --> LegacyGenerator
LegacyGenerator --> NoCopy
LegacyGenerator --> TableRows
TableRows --> LegacyValidator
LegacySpec --> LegacyValidator

Cli --> SchemaProfiler : profile-example /\ngenerate-from-example
ExampleFolder --> SchemaProfiler
SchemaProfiler --> FieldModels
SchemaProfiler --> EntityModels
SchemaProfiler --> DatasetModels
SchemaProfiler --> PiiMasking
SchemaProfiler --> DistributionProfiler
DistributionProfiler --> DatasetProfile
SchemaProfiler --> RelationshipProfiler
RelationshipProfiler --> RelationshipModel
RelationshipProfiler --> DatasetProfile
DatasetProfile --> ConstraintMiner
ConstraintMiner --> ConstraintModel
ConstraintMiner --> DatasetProfile

DatasetProfile --> Planner
DatasetSpecFile --> DatasetSpec
Planner --> DatasetSpec
DatasetSpec --> EntityGenerator
EntityGenerator --> NoCopy
EntityGenerator --> ConstraintSolver
ConstraintSolver --> DatasetRows

DatasetRows --> DatasetSchemaValidator
DatasetSpec --> DatasetSchemaValidator
DatasetRows --> RelationshipValidator
DatasetSpec --> RelationshipValidator
DatasetRows --> ConstraintValidator
DatasetSpec --> ConstraintValidator
DatasetSchemaValidator --> Reconciliation
RelationshipValidator --> Reconciliation
ConstraintValidator --> Reconciliation
Reconciliation --> DatasetReport

RuleFile --> RuleModels
RuleModels --> RulesEngine
TableRows --> RulesEngine : optional CLI flow
RulesEngine --> BusinessValidator
BusinessValidator --> BusinessReport

Cli --> CsvOut
Cli --> JsonOut
Cli --> ParquetOut
TableRows --> CsvOut
TableRows --> JsonOut
TableRows --> ParquetOut
DatasetRows --> CsvOut
DatasetRows --> JsonOut
DatasetRows --> ParquetOut
TableProfile --> Artifacts
LegacySpec --> Artifacts
DatasetProfile --> Artifacts
DatasetSpec --> Artifacts
LegacyValidator --> Artifacts
DatasetReport --> Artifacts
BusinessReport --> Artifacts
EntityGenerator --> Manifest
AgentWorkspace --> Artifacts
AgentBundle --> Artifacts

note right of DatasetProfile
  Dataset profiles are safe metadata:
  entities, field types, null ratios,
  sensitivity flags, distributions,
  inferred relationships, and inferred
  constraints. Raw sensitive values are
  not exposed.
end note

note bottom of ConstraintSolver
  The solver enforces deterministic
  relationship and constraint consistency
  after base entity rows are generated.
end note

note right of SqlSafety
  Trino access is read-only and bounded.
  Unsafe SQL, unrestricted SELECT *,
  multiple statements, and likely PII
  projections are rejected.
end note

note bottom of NoCopy
  Generated rows must be reproducible
  from seed and must not be shuffled,
  duplicated, or exported source rows.
end note

note right of ApprovalGate
  The agent layer can prepare safe metadata
  and specs, but generation waits until a
  human or calling client explicitly approves
  the reviewed workspace.
end note

@enduml
